# Database (PostgreSQL)
# Docker Compose: DB_HOST=db
# Local (no Docker): DB_HOST=127.0.0.1 and update both URLs below
POSTGRES_USER=kabana_user
POSTGRES_PASSWORD=kabana_pass
POSTGRES_DB=kabana_db
DB_HOST=db
DATABASE_URL=postgresql+asyncpg://kabana_user:kabana_pass@db:5432/kabana_db
SYNC_DATABASE_URL=postgresql://kabana_user:kabana_pass@db:5432/kabana_db

# Security
SECRET_KEY=change_this_to_a_secure_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
# Docker: MEDIA_ROOT=/app/storage, FTP_ENABLED=True
# Local without FTP container: MEDIA_ROOT=/absolute/path/to/storage, FTP_ENABLED=False
MEDIA_ROOT=/app/storage
FTP_ENABLED=True
FTP_HOST=ftp
FTP_PORT=21
FTP_USER=ftp_user
FTP_PASS=ftp_pass

# Scraper
SCRAPER_CONCURRENCY=20

# Frontend
DOMAIN_NAME=kabana.local

# pgAdmin (docker compose --profile dev)
PGADMIN_DEFAULT_EMAIL=admin@kabana.local
PGADMIN_DEFAULT_PASSWORD=admin
